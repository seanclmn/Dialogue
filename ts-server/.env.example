# Copy to `.env` and adjust. With `yarn start:dev` / `yarn start:prod`, Nest also
# loads `.env.development` or `.env.production` when present (same keys override).

NODE_ENV=development
PORT=8080

JWT_SECRET=

DB_HOST=
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Set to true to run pending TypeORM migrations on app startup (optional; many teams run `yarn migration:run:prod` in deploy instead).
# In development, migrations run on startup by default unless set to false.
TYPEORM_MIGRATIONS_RUN=false

GCS_BUCKET_NAME=
# Optional: path to a GCP service account key file (for local dev).
# On Cloud Run, leave unset — Application Default Credentials are used automatically.
GCS_KEY_FILENAME=
GCS_PROJECT_ID=

# Redis / GCP Memorystore
# For local dev, a plain `docker run -p 6379:6379 redis` works fine.
# On Cloud Run, set REDIS_HOST to your Memorystore instance IP (VPC connector required).
REDIS_HOST=localhost
REDIS_PORT=6379
# Set only if your Memorystore instance has AUTH enabled.
REDIS_PASSWORD=
# Set to "true" to enable TLS (required for Memorystore with in-transit encryption).
REDIS_TLS=false
