# Copy to `.env` and adjust. With `yarn start:dev` / `yarn start:prod`, Nest also
# loads `.env.development` or `.env.production` when present (same keys override).

NODE_ENV=development
PORT=8080

DB_HOST=
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Set to true to run pending TypeORM migrations on app startup (optional; many teams run `yarn migration:run:prod` in deploy instead).
TYPEORM_MIGRATIONS_RUN=false

GCS_BUCKET_NAME=
